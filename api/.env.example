# Stripe — test mode keys (set real ones before deploy)
# Get from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_replace_with_real_key
STRIPE_WEBHOOK_SECRET=whsec_replace_with_real_secret
STRIPE_PRICE_BRL_CENTS=990

# Redis (local default)
REDIS_URL=redis://localhost:6379/0

# Auth — HMAC secret for signed dashboard URLs (generate via: openssl rand -hex 32)
HMAC_SECRET=dev_change_me_in_production_use_openssl_rand_hex_32

# Frontend URL (used for Stripe success/cancel URLs)
FRONTEND_URL=http://localhost:3001

# CORS allowlist (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,https://br.codeflying.app,https://codeflying.app

# Cohort
COHORT_CAP=100
SIGNUP_CREDIT_BRL_CENTS=5000

# Cloudflare Turnstile (leave empty in dev to bypass verification)
TURNSTILE_SECRET_KEY=

# Document versions (recorded in Stripe Customer.metadata)
TERMS_VERSION=v1.0-2026-05-13
PRIVACY_VERSION=v1.0-2026-05-13
